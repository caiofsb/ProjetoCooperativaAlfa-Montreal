@page
@model Cooperativa.Web.Pages.Clientes.IndexModel

@{
    ViewData["Title"] = "Clientes";
}

<div class="pagina-clientes">
    <section class="hero-clientes">
        <div>
            <p class="etiqueta">Cooperativa Financeira Alfa</p>
            <h1>Gestão de Clientes</h1>
            <p>
                Tela moderna para demonstrar a integração entre Razor Pages,
                API .NET, COBOL, Helper e DB2.
            </p>
        </div>

        <div class="painel-fluxo">
            <span>Razor Pages</span>
            <strong>→</strong>
            <span>API .NET</span>
            <strong>→</strong>
            <span>COBOL</span>
            <strong>→</strong>
            <span>Helper</span>
            <strong>→</strong>
            <span>DB2</span>
        </div>
    </section>


    @if (Model.Resultado is not null)
    {
        var classeAlerta = Model.Resultado.Sucesso
            ? "resultado sucesso"
            : "resultado erro";

        <section class="@classeAlerta">
            <div>
                <p class="etiqueta">Retorno da operação</p>
                <h2>@Model.TituloResultado</h2>
                <p>@Model.Resultado.Mensagem</p>
            </div>

            <div class="codigo-retorno">
                <span>Código</span>
                <strong>@Model.Resultado.CodigoRetorno</strong>
            </div>
        </section>

        @if (Model.Resultado.Cliente is not null)
        {
            <section class="cliente-detalhe">
                <div>
                    <span>Código</span>
                    <strong>@Model.Resultado.Cliente.Codigo</strong>
                </div>

                <div>
                    <span>Nome</span>
                    <strong>@Model.Resultado.Cliente.Nome</strong>
                </div>

                <div>
                    <span>Email</span>
                    <strong>@Model.Resultado.Cliente.Email</strong>
                </div>

                <div>
                    <span>Telefone</span>
                    <strong>
                        @(Model.Resultado.Cliente.Telefone ?? "Não informado")
                    </strong>
                </div>
            </section>
        }

    }

    <section class="grade-clientes">
        <article class="cartao destaque">
            <div class="icone">🔎</div>
            <h2>Consultar cliente</h2>
            <p>Busca o cliente pelo código e mostra o retorno vindo do DB2.</p>

            <form method="post"
                  asp-page-handler="Consultar"
                 >

                <label asp-for="CodigoConsulta">
                    Código do cliente
                </label>

                <input asp-for="CodigoConsulta"
                       maxlength="6"
                       placeholder="000001" />

                <button type="submit">
                    Consultar cliente
                </button>
            </form>
        </article>

        <article class="cartao cadastro-card">
            <div class="icone">➕</div>
            <h2>Cadastrar cliente</h2>
            <p>
                Antes de inserir, o sistema abre uma confirmação com os dados.
            </p>

            <form method="post"
                  asp-page-handler="Cadastrar"
                  id="formCadastro"
                  >

                <label asp-for="Cadastro.Nome">
                    Nome
                </label>

                <input asp-for="Cadastro.Nome"
                       maxlength="30"
                       placeholder="Nome do cliente" />

                <label asp-for="Cadastro.Email">
                    Email
                </label>

                <input asp-for="Cadastro.Email"
                       maxlength="60"
                       placeholder="cliente@email.com" />

                <label asp-for="Cadastro.Telefone">
                    Telefone
                </label>

                <input asp-for="Cadastro.Telefone"
                       maxlength="11"
                       placeholder="11999999999" />

                <button type="button"
                        onclick="abrirConfirmacaoCadastro()">
                    Revisar cadastro
                </button>
            </form>
        </article>

        <article class="cartao">
            <div class="icone">✏️</div>
            <h2>Atualizar contato</h2>
            <p>Atualiza email e telefone mantendo o cadastro do cliente.</p>

            <form method="post"
                  asp-page-handler="Atualizar"
                  >

                <label asp-for="CodigoAtualizacao">
                    Código do cliente
                </label>

                <input asp-for="CodigoAtualizacao"
                       maxlength="6"
                       placeholder="000001" />

                <label asp-for="Contato.Email">
                    Novo email
                </label>

                <input asp-for="Contato.Email"
                       maxlength="60"
                       placeholder="novo@email.com" />

                <label asp-for="Contato.Telefone">
                    Novo telefone
                </label>

                <input asp-for="Contato.Telefone"
                       maxlength="11"
                       placeholder="11999999999" />

                <button type="submit">
                    Atualizar contato
                </button>
            </form>
        </article>
    </section>
</div>

<div id="modalConfirmacaoCadastro"
     class="modal-confirmacao"
     hidden>

    <div class="modal-conteudo">
        <p class="etiqueta">Confirmação obrigatória</p>
        <h2>Confirmar cadastro</h2>

        <p>
            Confira os dados antes de inserir o cliente no DB2.
        </p>

        <div class="resumo-confirmacao">
            <p>
                <strong>Nome:</strong>
                <span id="confirmacaoNome"></span>
            </p>

            <p>
                <strong>Email:</strong>
                <span id="confirmacaoEmail"></span>
            </p>

            <p>
                <strong>Telefone:</strong>
                <span id="confirmacaoTelefone"></span>
            </p>
        </div>

        <div class="acoes-modal">
            <button type="button"
                    class="botao-secundario"
                    onclick="fecharConfirmacaoCadastro()">
                Voltar e corrigir
            </button>

            <button type="submit"
                    form="formCadastro">
                Confirmar cadastro
            </button>
        </div>
    </div>
</div>

<style>
    body {
        background:
            radial-gradient(circle at top left, #dbeafe 0, transparent 30%),
            linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
    }

    .pagina-clientes {
        max-width: 1180px;
        margin: 0 auto;
        padding: 32px 20px;
    }

    .hero-clientes {
        display: grid;
        grid-template-columns: 1.3fr 1fr;
        gap: 24px;
        align-items: center;
        margin-bottom: 24px;
        padding: 28px;
        border-radius: 24px;
        background: #0f172a;
        color: #ffffff;
        box-shadow: 0 20px 50px rgba(15, 23, 42, 0.25);
    }

    .hero-clientes h1 {
        margin: 6px 0 10px;
        font-size: 2.4rem;
    }

    .hero-clientes p {
        margin: 0;
        color: #cbd5e1;
    }

    .etiqueta {
        margin: 0;
        color: #38bdf8;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .painel-fluxo {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
        justify-content: center;
        padding: 18px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.08);
    }

    .painel-fluxo span {
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
        font-weight: 700;
    }

    .grade-clientes {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(295px, 1fr));
        gap: 20px;
        margin-top: 24px;
    }

    .cartao {
        padding: 22px;
        border: 1px solid rgba(148, 163, 184, 0.35);
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.88);
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
        backdrop-filter: blur(10px);
    }

    .cartao h2 {
        margin: 8px 0;
        color: #0f172a;
    }

    .cartao p {
        color: #64748b;
    }

    .destaque {
        border-color: rgba(37, 99, 235, 0.3);
    }

    .cadastro-card {
        border-color: rgba(14, 165, 233, 0.4);
    }

    .icone {
        width: 44px;
        height: 44px;
        display: grid;
        place-items: center;
        border-radius: 14px;
        background: #eff6ff;
        font-size: 1.4rem;
    }

    label {
        display: block;
        margin-top: 14px;
        margin-bottom: 6px;
        color: #334155;
        font-weight: 700;
    }

    input {
        width: 100%;
        padding: 12px 13px;
        border: 1px solid #cbd5e1;
        border-radius: 12px;
        background: #ffffff;
        box-sizing: border-box;
        outline: none;
    }

    input:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
    }

    button {
        width: 100%;
        margin-top: 18px;
        padding: 12px 16px;
        border: none;
        border-radius: 12px;
        background: #2563eb;
        color: #ffffff;
        cursor: pointer;
        font-weight: 800;
    }

    button:hover {
        filter: brightness(0.96);
    }

    .botao-secundario {
        background: #ffffff;
        color: #0f172a;
        border: 1px solid #cbd5e1;
    }

    .resultado {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        align-items: center;
        margin-bottom: 18px;
        padding: 20px;
        border-radius: 20px;
        box-shadow: 0 16px 35px rgba(15, 23, 42, 0.08);
    }

    .resultado h2 {
        margin: 4px 0;
    }

    .resultado p {
        margin: 0;
    }

    .sucesso {
        border: 1px solid #86efac;
        background: #f0fdf4;
    }

    .erro {
        border: 1px solid #fca5a5;
        background: #fff1f2;
    }

    .codigo-retorno {
        min-width: 120px;
        padding: 14px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.7);
        text-align: center;
    }

    .codigo-retorno span {
        display: block;
        color: #64748b;
        font-size: 0.8rem;
    }

    .codigo-retorno strong {
        font-size: 1.4rem;
    }

    .cliente-detalhe {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: 14px;
        margin-bottom: 18px;
    }

    .cliente-detalhe div {
        padding: 16px;
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 10px 26px rgba(15, 23, 42, 0.08);
    }

    .cliente-detalhe span {
        display: block;
        margin-bottom: 6px;
        color: #64748b;
        font-size: 0.82rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .cliente-detalhe strong {
        color: #0f172a;
    }

    .terminal-legado {
        overflow: hidden;
        margin-bottom: 20px;
        border-radius: 20px;
        background: #020617;
        color: #e2e8f0;
        box-shadow: 0 20px 50px rgba(2, 6, 23, 0.22);
    }

    .terminal-topo {
        display: flex;
        gap: 8px;
        align-items: center;
        padding: 12px 16px;
        background: #111827;
    }

    .terminal-topo strong {
        margin-left: 8px;
        color: #f8fafc;
    }

    .bolinha {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: #38bdf8;
    }

    .terminal-legado ol {
        margin: 0;
        padding: 18px 24px 20px 42px;
    }

    .terminal-legado li {
        margin-bottom: 8px;
        font-family: Consolas, monospace;
    }

    .terminal-legado.carregando li::after {
        content: "";
    }

    .modal-confirmacao[hidden],
    #processoAoVivo[hidden] {
        display: none;
    }

    .modal-confirmacao {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        background: rgba(15, 23, 42, 0.72);
        z-index: 9999;
    }

    .modal-conteudo {
        width: 100%;
        max-width: 480px;
        padding: 26px;
        border-radius: 24px;
        background: #ffffff;
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
    }

    .modal-conteudo h2 {
        margin: 6px 0 8px;
    }

    .resumo-confirmacao {
        margin-top: 16px;
        padding: 16px;
        border-radius: 16px;
        background: #f8fafc;
    }

    .resumo-confirmacao p {
        margin: 8px 0;
    }

    .acoes-modal {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 18px;
    }

@@media (max-width: 780px) {
    .hero-clientes {
        grid-template-columns: 1fr;
    }

    .resultado {
        align-items: stretch;
        flex-direction: column;
    }
}
</style>

<script>
    function abrirConfirmacaoCadastro() {
        const nome = document.getElementById("Cadastro_Nome").value.trim();
        const email = document.getElementById("Cadastro_Email").value.trim();
        const telefone = document.getElementById("Cadastro_Telefone").value.trim();

        if (!nome) {
            alert("Informe o nome antes de revisar o cadastro.");
            return;
        }

        if (!email) {
            alert("Informe o email antes de revisar o cadastro.");
            return;
        }

        document.getElementById("confirmacaoNome").textContent = nome;
        document.getElementById("confirmacaoEmail").textContent = email;
        document.getElementById("confirmacaoTelefone").textContent =
            telefone || "Não informado";

        document.getElementById("modalConfirmacaoCadastro").hidden = false;
    }

    function fecharConfirmacaoCadastro() {
        document.getElementById("modalConfirmacaoCadastro").hidden = true;
    }

 
</script>